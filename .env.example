# LuminaVaultServer — environment variable template.
#
# Copy to `.env` for local development. Production loads through
# docker-compose.production.yml, which references the SAME variable
# names via `${VAR:-default}` / `${VAR:?required}`. Keys are read in
# code as `ConfigKey("camelCase.dot.path")`; the Configuration framework
# matches them against SCREAMING_SNAKE_CASE env vars (so
# `hermes.gatewayUrl` ↔ `HERMES_GATEWAY_URL`).
#
# See docs/CONFIG.md for the full precedence rules.

# --- Postgres ---
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=luminavault
POSTGRES_DATABASE=luminavault
POSTGRES_PASSWORD=luminavault

# --- Fluent ORM ---
# FLUENT_ENABLED=false disables Postgres entirely (used by some test paths).
FLUENT_ENABLED=true
FLUENT_AUTOMIGRATE=true

# --- Hermes (LLM gateway) ---
HERMES_GATEWAY_URL=http://hermes:8642
HERMES_GATEWAY_KIND=filesystem
HERMES_DATA_ROOT=/app/data/hermes
HERMES_DEFAULT_MODEL=hermes-3
# HER-300 — Managed default brain model surfaced to the iOS UI.
# Must match the model configured in ~/.hermes/config.yaml on the
# Hermes container.
HERMES_DEFAULT_MANAGED_MODEL=qwen/qwen-2.5-72b-instruct
HERMES_MANAGED_PROVIDER_HINT=openrouter
# Bearer key shared between the hermes container (API_SERVER_KEY env) and
# the app's outbound HTTP clients. Required: hermes refuses to bind to
# 0.0.0.0 without it. Generate via `make hermes-bootstrap`.
HERMES_API_KEY=

# --- Observability ---
# App ships ALL signals (traces, metrics, logs) to otel-collector. The
# collector then fans out: traces → jaeger, logs → PostHog, metrics → debug.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://otel-collector:4318/v1/logs
OTEL_SERVICE_NAME=LuminaVaultServer
LOG_LEVEL=debug
# HER-236: PostHog OTLP project token. Consumed by the otel-collector
# container only — the app does not see this value. Get it from
# app.posthog.com → Project Settings → "OpenTelemetry".
POSTHOG_OTEL_TOKEN=
# Backend traces/logs fan out to Sentry through
# otel-collector-config.production.yaml. The collector's Sentry exporter
# requires an org-scoped auth token, not the client DSN.
SENTRY_BASE_URL=https://sentry.io
SENTRY_ORG_SLUG=
SENTRY_PROJECT_SLUG=luminavault-server
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=local

# --- Auth / JWT ---
# Legacy single-key path. Used when JWT_HMAC_SECRETS (below) is empty.
JWT_HMAC_SECRET=change-me-32-chars-minimum-do-not-use-in-prod
JWT_KID=lv-default
# HER-33 multi-key rotation. Ordered csv of `kid:secret,kid:secret` pairs;
# the first entry is the active signer, the rest stay loaded so in-flight
# tokens verify during the rollover window. Each secret must be 32+ chars.
# Leave empty in dev to use JWT_HMAC_SECRET + JWT_KID. See docs/CONFIG.md
# section "JWT key rotation" for the zero-downtime procedure.
JWT_HMAC_SECRETS=

# --- Email magic-link / OTP delivery (HER-33) ---
# `logging` (default) writes OTPs to stderr — dev/CI only.
# `resend` posts via the Resend HTTP API; required in production.
EMAIL_KIND=logging
EMAIL_RESEND_APIKEY=
# Sender domain MUST be verified in Resend. Format `Name <addr@domain>`
# or bare `addr@domain`.
EMAIL_FROM_ADDRESS=
# Optional. Empty omits the Reply-To header.
EMAIL_REPLY_TO=

# --- OAuth providers ---
# Empty client ID disables the provider (endpoint returns 503).
OAUTH_APPLE_CLIENTID=
OAUTH_GOOGLE_CLIENTID=
OAUTH_X_CLIENTID=

# --- Admin (HER-30 bootstrap + admin REST surface) ---
# `swift run App bootstrap-admin` / `./setup.sh` consume these. Leave
# EMAIL/PASSWORD blank to skip the seed. Password ≥ 12 chars; re-runs
# are idempotent.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_USERNAME=admin
# Bearer token required for `/admin/*` endpoints. Empty disables them.
ADMIN_TOKEN=

# --- CORS ---
# Prod MUST set an explicit comma-separated list. Empty in dev = wildcard
# in the dev compose file. The prod compose declares this :?required so
# the container fails fast if it's missing.
CORS_ALLOWEDORIGINS=

# --- WebAuthn / Passkeys ---
WEBAUTHN_ENABLED=false
WEBAUTHN_RELYING_PARTY_ID=localhost
WEBAUTHN_RELYING_PARTY_NAME=LuminaVault
WEBAUTHN_RELYING_PARTY_ORIGIN=http://localhost:8080

# --- BYO Hermes / encrypted user credentials ---
# 32 random bytes, base64 encoded. Enables /v1/settings/hermes, per-user
# provider credentials, XAI OAuth container flows, and Hermes gateways.
# Generate: openssl rand -base64 32
LV_SECRET_MASTER_KEY=
LV_ENVIRONMENT=dev
BYO_HERMES_ALLOW_PRIVATE=false

# --- Per-tenant Hermes container manager ---
HERMES_PER_TENANT_IMAGE=nousresearch/hermes-agent:latest
HERMES_PER_TENANT_NETWORK=luminavault-hermes-net
HERMES_PER_TENANT_DATA_ROOT_BASE=/app/data/hermes-tenants
HERMES_PER_TENANT_PORT_RANGE_START=9000
HERMES_PER_TENANT_PORT_RANGE_END=9500
HERMES_PER_TENANT_IDLE_TTL_SECONDS=1800
DOCKER_BINARY_PATH=/usr/bin/docker

# --- APNS push notifications ---
APNS_ENABLED=false
APNS_BUNDLE_ID=com.example.luminavault
APNS_TEAM_ID=YOUR_TEAM_ID
APNS_KEY_ID=YOUR_KEY_ID
APNS_PRIVATE_KEY_PATH=/absolute/path/to/apns-key.pem
APNS_ENVIRONMENT=development
APNS_DEVICE_TOKEN=

# --- Vault filesystem ---
VAULT_ROOT_PATH=/var/lib/luminavault

# --- Usage metering (free-tier daily caps) ---
USAGE_FREE_MTOK_DAILY=1.0
USAGE_PER_SKILL_MTOK_DAILY=0.2
USAGE_DEGRADE_MODEL=hermes-3-small

# --- Billing enforcement ---
# When enabled, expired-tier users get 402 on metered endpoints.
BILLING_ENFORCEMENT_ENABLED=false
# Defaults to VAULT_ROOT_PATH if empty.
BILLING_COLD_STORAGE_PATH=

# --- RevenueCat webhook (billing tier sync) ---
# Server validates incoming POSTs to /v1/billing/revenuecat against
# this secret. Empty secret rejects all webhooks.
REVENUECAT_WEBHOOK_SECRET=

# --- Rate limiting ---
# `memory` for single-instance dev. Production should use a shared
# backend once we add a Redis/Postgres adapter.
RATE_LIMIT_STORAGE_KIND=memory

# --- SMS / phone auth ---
# `logging` writes the OTP to stderr (dev). `twilio` requires the three
# TWILIO_* vars below. `fixed` returns PHONE_FIXED_OTP every time
# (CI / TestFlight regression suite).
SMS_KIND=logging
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Force a known OTP code through the phone OTP / magic-link paths.
# Leave empty in production — non-empty means anyone with the value
# can sign in as any user with that flow.
PHONE_FIXED_OTP=
MAGIC_FIXED_OTP=

# --- Gemini (vision + multimodal fallback) ---
GEMINI_API_KEY=

# --- TTS (POST /v1/tts) ---
# OpenAI-compatible only at the moment. Empty PROVIDER_*_APIKEY = the
# endpoint stays unregistered.
TTS_PROVIDER=openai
TTS_DEFAULT_MODEL=tts-1
TTS_CHARACTERS_DAILY=1000000

# --- Vision embeddings (POST /v1/vision/embed) ---
# Active provider; default `cohere`. Set the matching APIKEY to enable.
VISION_EMBED_PROVIDER=cohere
VISION_EMBED_PROVIDER_COHERE_APIKEY=
VISION_EMBED_PROVIDER_COHERE_BASEURL=
VISION_EMBED_PROVIDER_COHERE_MODEL=embed-english-v3.0

# --- HER-203 — STT (POST /v1/transcribe) ---
# Active provider; default `groq`. Set the matching APIKEY to enable.
# Empty APIKEY = provider unregistered = endpoint returns 503.
TRANSCRIBE_PROVIDER=groq
TRANSCRIBE_PROVIDER_GROQ_APIKEY=
TRANSCRIBE_PROVIDER_GROQ_BASEURL=https://api.groq.com
TRANSCRIBE_PROVIDER_GROQ_MODEL=whisper-large-v3
# Mtok-equivalent units credited per second of audio. Per provider so
# we can re-price independently.
TRANSCRIBE_RATECARD_GROQ_MTOKPERSECOND=0.0001

# --- HER-164 — OpenAI-compatible LLM providers backing free-tier traffic ---
# Empty APIKEY = provider unregistered. BASEURL is optional override;
# defaults are compiled into OpenAICompatibleAdapter.
LLM_PROVIDER_TOGETHER_APIKEY=
LLM_PROVIDER_TOGETHER_BASEURL=
LLM_PROVIDER_GROQ_APIKEY=
LLM_PROVIDER_GROQ_BASEURL=
LLM_PROVIDER_FIREWORKS_APIKEY=
LLM_PROVIDER_FIREWORKS_BASEURL=
LLM_PROVIDER_DEEPINFRA_APIKEY=
LLM_PROVIDER_DEEPINFRA_BASEURL=
# DeepSeek-direct is Chinese-hosted; only registered when its key is set.
# Routing also requires the calling user to have privacy_no_cn_origin=false
# (see ModelOriginRegistry / ProviderKind.region).
LLM_PROVIDER_DEEPSEEKDIRECT_APIKEY=
LLM_PROVIDER_DEEPSEEKDIRECT_BASEURL=
LLM_PROVIDER_XAI_APIKEY=
LLM_PROVIDER_XAI_BASEURL=
LLM_PROVIDER_OPENAI_APIKEY=
LLM_PROVIDER_OPENAI_BASEURL=
LLM_PROVIDER_OPENROUTER_APIKEY=
LLM_PROVIDER_OPENROUTER_BASEURL=
LLM_PROVIDER_ANTHROPIC_APIKEY=
LLM_PROVIDER_ANTHROPIC_BASEURL=
LLM_PROVIDER_OLLAMA_BASEURL=

# --- HER-134 — text-embedding provider selection ---
# Selects which real EmbeddingService backs semantic memory + KB recall.
# Values: `openai` (text-embedding-3-small, 1536 dims, reuses
# LLM_PROVIDER_OPENAI_APIKEY) | `hermesLocal` (per-tenant Hermes container
# at /v1/embeddings) | `nomic` (Nomic Atlas, 768 dims zero-padded to 1536)
# | `deterministic` (hash-based dev stub; default).
EMBEDDING_PROVIDER=deterministic
# Comma-separated fallback chain. Transient/network failures on the active
# provider advance to the next. Permanent failures (auth, decode, endpoint
# missing) propagate. Example: `EMBEDDING_FALLBACK_CHAIN=hermesLocal,openai`.
EMBEDDING_FALLBACK_CHAIN=
# Per-tenant monthly token cap. `0` disables the guard (dev).
EMBEDDING_MONTHLY_TOKEN_CAP_DEFAULT=2000000
# Nomic Atlas API key. Required when `EMBEDDING_PROVIDER=nomic` (or when
# nomic appears in the fallback chain). Empty = nomic adapter not registered.
EMBEDDING_NOMIC_APIKEY=

# --- Deployment overrides (compose-side) ---
# HTTP_HOST=0.0.0.0
# APP_IMAGE=ghcr.io/yourusername/luminavault-server:latest
# APP_PORT=8080
