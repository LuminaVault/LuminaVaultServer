# LuminaVaultServer production reverse proxy.
#
# Caddy terminates TLS and speaks HTTP/2 (and HTTP/3 over :443/udp) to clients
# automatically once it has a certificate. The Swift app stays HTTP/1.1 on the
# internal compose network; WebSocket upgrades (chat SSE/WS) are proxied
# transparently — no extra matcher needed.
#
# DNS is not pointed yet. Once `api.luminavault.fyi` resolves to this host,
# Caddy provisions a Let's Encrypt cert on first request (ports 80 + 443 must
# be open). Set the ACME contact email below before going live.

{
	email fernandocorreia316@gmail.com
}

api.luminavault.fyi {
	# Skip compression for SSE endpoints (all end in /stream). Caddy's `encode`
	# buffers up to minimum_length before emitting, which batches token frames
	# and breaks live streaming. Everything else still gets compressed.
	@compressible {
		not path */stream
	}
	encode @compressible zstd gzip
	reverse_proxy app:8080
}

# Apex marketing/legal site. Serves the static pages in ./web (mounted at
# /srv/web in the caddy container). Clean URLs: /privacy -> privacy.html,
# /terms -> terms.html. The iOS app's LV_PRIVACY_URL / LV_TERMS_URL and the
# App Store privacy-policy URL all point here. ACME cert issues once the apex
# A record resolves to this host (it does).
luminavault.fyi {
	encode zstd gzip
	root * /srv/web
	try_files {path} {path}.html {path}/index.html /index.html
	file_server
}

# --- Local / pre-DNS testing -------------------------------------------------
# To verify HTTP/2 before DNS exists, comment out the block above and use this
# self-signed variant, then `curl -kI --http2 https://localhost/health`:
#
# localhost {
# 	tls internal
# 	encode zstd gzip
# 	reverse_proxy app:8080
# }
