meta {
  name: Me
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/v1/auth/me
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("returns identity", function() {
    const b = res.getBody();
    expect(b.userId).to.be.a("string");
    expect(b.email).to.be.a("string");
    expect(b.isVerified).to.be.a("boolean");
  });
}
