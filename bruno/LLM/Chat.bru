meta {
  name: Chat
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/v1/llm/chat
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "messages": [
      { "role": "user", "content": "Say hi in 5 words." }
    ],
    "temperature": 0.7
  }
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("assistant content present", function() {
    expect(res.getBody().message.content).to.be.a("string");
  });
  test("model echoed back", function() {
    expect(res.getBody().model).to.be.a("string");
  });
}

docs {
  Sends a chat completion to the user's Hermes profile (profile name == username).
  Server attaches `X-Hermes-Profile: <username>` and proxies to
  `http://hermes:8642/v1/chat/completions`.

  Watch live via `docker logs -f hermes-agent` while this fires.
  If 502/badGateway, run `docker exec hermes-agent ls /opt/data/profiles/`
  to confirm the profile dir exists.
}
