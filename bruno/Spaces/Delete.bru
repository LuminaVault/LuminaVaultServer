meta {
  name: Delete
  type: http
  seq: 5
}

delete {
  url: {{baseUrl}}/v1/spaces/{{spaceId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("status 204", function() {
    expect(res.status).to.equal(204);
  });
}

docs {
  Deletes the DB row. The on-disk folder is NOT erased — it's renamed to
  `_deleted_<unix-timestamp>_<slug>` under the same raw/ root so notes
  can be recovered by an operator. Cleanup is an ops concern.
}
