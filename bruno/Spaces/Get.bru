meta {
  name: Get
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/v1/spaces/{{spaceId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("matches spaceId", function() {
    expect(res.getBody().id).to.equal(bru.getEnvVar("spaceId"));
  });
}
