meta {
  name: List
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/v1/spaces
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("returns spaces array", function() {
    expect(res.getBody().spaces).to.be.an("array");
  });
}
